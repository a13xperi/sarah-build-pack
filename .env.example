# Battlestation — Isolated Stack config. Copy to .env and fill in YOUR values.
# These point the whole coordination layer at your own Supabase project.

SUPA_URL=https://YOUR-PROJECT-ref.supabase.co
SUPA_KEY=YOUR-supabase-anon-key

# Optional
DASHBOARD_URL=                       # your coordination dashboard, if you deploy one
PERMISSION_LOG_DIR=$HOME/.claude-permission-feed
BS_DEFAULT_COMPANY=default           # label used in build_ledger when no repo map matches
BS_GITHUB_USER=                      # your GitHub user/org — token-watch opens commits at github.com/$BS_GITHUB_USER/<repo>
